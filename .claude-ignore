# Claude Code 忽略文件 - 专门用于优化 token 使用
# 比 .gitignore 更精确的 Claude Code 缓存控制

# ===== Obsidian 插件文件（主要缓存消耗）=====
.obsidian/plugins/*/main.js
.obsidian/plugins/*/styles.css
.obsidian/plugins/*/manifest.json
.obsidian/plugins/*/*.js
.obsidian/plugins/*/*.css
.obsidian/plugins/*/*.map

# ===== Obsidian 工作区文件 =====
.obsidian/workspace.json
.obsidian/workspace-mobile.json
.obsidian/workspace-beta.json
.obsidian/graph.json
.obsidian/graph-cache.json

# ===== 大型可执行文件 =====
*.exe
*.msi
*.dmg
*.pkg
*.deb
*.rpm

# ===== 压缩文件 =====
*.zip
*.tar
*.tar.gz
*.tar.bz2
*.7z
*.rar

# ===== 媒体文件（按大小）=====
*.mp4
*.avi
*.mov
*.wmv
*.flv
*.mkv
*.webm

# ===== 音频文件 =====
*.mp3
*.wav
*.flac
*.aac
*.ogg

# ===== 大型图片文件 =====
*.psd
*.ai
*.sketch
*.fig
*.xd

# ===== 数据库和备份 =====
*.db
*.sqlite
*.sqlite3
*.bak
*.backup

# ===== 日志文件 =====
*.log
*.log.*

# ===== 临时构建文件 =====
dist/
build/
out/
target/

# ===== 缓存目录 =====
cache/
tmp/
temp/

# ===== 特定于工作区的优化 =====
# 如果某些目录特别大但不必要，可以在这里添加
# cherrystudio生成文件/  # 如果这个目录很大且不常使用